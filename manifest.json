{
  "manifest_version": 3,
  "name": "ReqAI Agent",
  "version": "1.0.0",
  "description": "AI-Powered Requirement Extraction System",
  "action": {
    "default_popup": "popup.html",
    "default_title": "ReqAI Agent"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "http://localhost:5678/*",
    "https://localhost:5678/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}